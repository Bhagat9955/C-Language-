#include <stdio.h>
#include <string.h>

void reverseWords(char *s) {
    int n = strlen(s);
    char result[n + 1];
    int idx = 0;

    int i = n - 1;

    while (i >= 0) {
        while (i >= 0 && s[i] == ' ') i--;

        if (i < 0) break;

        int j = i;

        while (j >= 0 && s[j] != ' ') j--;

        for (int k = j + 1; k <= i; k++) {
            result[idx++] = s[k];
        }

        result[idx++] = ' ';

        i = j - 1;
    }

    if (idx > 0) idx--;

    result[idx] = '\0';

    strcpy(s, result);
}

int main() {
    char s[] = "  hello world  ";
    reverseWords(s);
    printf("%s\n", s);
    return 0;
}
